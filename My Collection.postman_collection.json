        {
          "name": "POST API",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "\r",
                  "pm.test(\"Status code is 201\", function () {\r",
                  "    pm.expect(pm.response.code).to.eql(201);\r",
                  "});\r",
                  "\r",
                  "\r",
                  "pm.test(\"Name is correct\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.name).to.eql(\"Sanchit\");\r",
                  "});\r",
                  "\r",
                  "\r",
                  "pm.test(\"Job is correct\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.job).to.eql(\"QA Engineer\");\r",
                  "});\r",
                  "\r",
                  "// ✅ Check ID generated\r",
                  "pm.test(\"ID is generated\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.id).to.not.be.null;\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"name\": \"Sanchit\",\r\n  \"job\": \"QA Engineer\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
